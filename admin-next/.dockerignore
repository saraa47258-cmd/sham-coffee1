# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
.next
build
out
dist

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment files (keep templates only)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Git
.git
.gitignore

# Documentation
*.md
!README.md

# Tests
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage

# Backup files
backups
*.backup

# Development files
*.log
.eslintcache
.turbo

# Docker files (prevent recursion)
Dockerfile*
docker-compose*
.dockerignore
